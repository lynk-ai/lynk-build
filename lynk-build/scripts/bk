#!/usr/bin/env python3
# BUNDLE BUILD (read-only) — rendered from lynk-book @ c032dfc (2026-07-16) for plugin "lynk-build".
# Write verbs are not present in this copy; authoring happens in the lynk-book repo.
"""bk — the library CLI. CandleKeep's `ck`, pointed at a folder instead of a cloud.

Verbs:
  bk list [--json]                     books on the shelf
  bk toc <book> [--json]               a book's pages (slug, type, description)
  bk read <book>:<pages>[,<pages>...]  read pages ('all', 'index', or comma-separated slugs)
  bk create <slug> --title "..."       scaffold a new book (index.md + log.md)
  bk put <book>:<page> --file <path>   write a page (or stdin with --file -)
  bk grep <term> [--book <slug>]       deterministic full-text search
  bk index <book> [--write]            regenerate index.md from page frontmatter
  bk log <book> --entry "..."          append a dated changelog entry
  bk lint <book>|library [--json]      deterministic gate layer (error/warn)
  bk coverage [--json]                 which promises have a live eval (matrix)
  bk gate <slug> [--verdict PASS|REJECT --by X]  lint a draft + record a hash-bound verdict
  bk promote <slug> [--force]          move a gated draft into library/ (the only path in)

The enforced write path: drafts live in drafts/<slug>/, never library/. `bk gate`
runs lint (fail-closed) and records a verdict artifact (.bk/verdicts/<slug>.json)
binding a PASS to each page's sha256. `bk promote` refuses unless a PASS verdict
matches the current content — edit a draft after gating and it must re-gate.

Substrate rules (Book 2, library-layout): folder = book, .md files = pages,
index.md + log.md reserved. Slugs: ^[a-z0-9-]+$ — enforced on every write.
Writes are atomic (temp + rename). Reads are logged per session with a content
hash (.bk/reads/<session>.jsonl) — freshness is load-bearing.

FRONTMATTER SUBSET (strict on writes, tolerant on reads):
  ---
  key: scalar value            # keys: [a-z_]+ ; value = rest of line
  tags: [one, two, three]      # flow-style list of scalars
  rules:                       # the ONE documented nested shape
    - id: quality/sourced-statements
      severity: error          # error | warn
      scope: page              # page | book
      statement: one line for the writer's brief
      gate_criteria: >
        3-6 sentences for the verifier, folded
        from indented continuation lines.
  ---
Anything else (tabs, other nesting, block lists outside `rules:`) is a
strict-parse error. BK_ROOT overrides the repo root (used by tests); BK_DATA
overrides where .bk/ state lands (reads, verdicts) — content and state can live
apart, e.g. books in a plugin bundle, telemetry in the consumer project.
"""
import sys, os, re, json, hashlib, argparse, datetime, pathlib, shutil

def _autodetect_root():
    # bk may live at the content root (dev repo) or one level down (a bundle's
    # scripts/bk). Find the ancestor that actually holds library/.
    here = pathlib.Path(__file__).resolve().parent
    for cand in (here, here.parent):
        if (cand / "library").is_dir():
            return cand
    return here
ROOT = pathlib.Path(os.environ["BK_ROOT"]) if os.environ.get("BK_ROOT") else _autodetect_root()
# BUNDLE_BUILD is flipped to True by scripts/bundle.sh in the SHIPPED copy of
# this file. A bundle build has NO write verbs at all — put/create/log/promote
# and index --write are never registered, so the capability doesn't exist in
# the shipped CLI (stronger than guarding it). Dev builds keep everything.
BUNDLE_BUILD = True
# BK_DATA splits state from content: books are read from BK_ROOT (e.g. a plugin
# bundle), while .bk/ state (reads log, verdicts) is written under BK_DATA
# (e.g. the consumer project). Dev default: single-root layout. Bundle default
# (BK_DATA unset): the CALLER's cwd — state must never land in the shipped
# plugin dir, even when a caller forgets the env.
_DATA_DEFAULT = pathlib.Path.cwd() / ".bk" if BUNDLE_BUILD else ROOT / ".bk"
DATA = pathlib.Path(os.environ.get("BK_DATA", str(_DATA_DEFAULT)))
LIB = ROOT / "library"
RESERVED = {"index.md", "log.md"}
SLUG_RE = re.compile(r"^[a-z0-9-]+$")
PAGE_BUDGET_LINES = 120
REGISTRY_ENFORCED = False  # flips to True once the Phase 1 rule-registry merges


def die(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


# ---------------- frontmatter: strict subset parser ----------------

class FrontmatterError(ValueError):
    pass


def _parse_scalar(v):
    v = v.strip()
    if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'":
        v = v[1:-1]
    return v


def _parse_flow_list(v, ln):
    inner = v.strip()[1:-1].strip()
    if not inner:
        return []
    return [_parse_scalar(x) for x in inner.split(",")]


def parse_frontmatter_strict(text):
    """Strict subset parse -> (meta, body). Raises FrontmatterError."""
    if not text.startswith("---\n"):
        raise FrontmatterError("no frontmatter block (must start with '---')")
    lines = text.split("\n")
    meta, i = {}, 1
    n = len(lines)
    while i < n:
        line = lines[i]
        if line.strip() == "---":
            body = "\n".join(lines[i + 1:]).lstrip("\n")
            return meta, body
        if "\t" in line:
            raise FrontmatterError(f"line {i+1}: tabs are not allowed")
        if not line.strip():
            i += 1
            continue
        m = re.match(r"^([a-z_]+):(.*)$", line)
        if not m:
            raise FrontmatterError(f"line {i+1}: expected 'key: value', got {line!r}")
        key, rest = m.group(1), m.group(2)
        rest = rest.strip()
        if key == "rules" and rest == "":
            items, i = _parse_rules_block(lines, i + 1)
            meta["rules"] = items
            continue
        if rest == "":
            raise FrontmatterError(f"line {i+1}: empty value for '{key}' (only 'rules:' may open a block)")
        if rest.startswith("["):
            if not rest.endswith("]"):
                raise FrontmatterError(f"line {i+1}: unterminated flow list")
            meta[key] = _parse_flow_list(rest, i + 1)
        elif rest in (">", "|"):
            raise FrontmatterError(f"line {i+1}: multi-line scalars only allowed inside rules entries")
        else:
            meta[key] = _parse_scalar(rest)
        i += 1
    raise FrontmatterError("unterminated frontmatter block (missing closing '---')")


_RULE_KEYS = {"id", "severity", "scope", "statement", "gate_criteria"}


def _parse_rules_block(lines, i):
    """Parse the documented nested rules shape starting at lines[i]."""
    items = []
    n = len(lines)
    while i < n:
        line = lines[i]
        if line.strip() == "---" or (line and not line.startswith(" ")):
            break  # end of rules block
        if not line.strip():
            i += 1
            continue
        m = re.match(r"^  - ([a-z_]+): (.+)$", line)
        if not m:
            raise FrontmatterError(f"line {i+1}: rules item must start '  - key: value', got {line!r}")
        item = {}
        key, val = m.group(1), m.group(2)
        if key not in _RULE_KEYS:
            raise FrontmatterError(f"line {i+1}: unknown rule key '{key}'")
        item[key] = _parse_scalar(val)
        i += 1
        while i < n:
            line = lines[i]
            if not line.strip():
                i += 1
                continue
            m2 = re.match(r"^    ([a-z_]+): (.*)$", line)
            if not m2:
                break
            k2, v2 = m2.group(1), m2.group(2).strip()
            if k2 not in _RULE_KEYS:
                raise FrontmatterError(f"line {i+1}: unknown rule key '{k2}'")
            if v2 in (">", "|"):
                fold = " " if v2 == ">" else "\n"
                parts, i = _collect_indented(lines, i + 1, indent=6)
                item[k2] = fold.join(parts).strip()
            elif v2 == "":
                raise FrontmatterError(f"line {i+1}: empty value for rule key '{k2}'")
            else:
                item[k2] = _parse_scalar(v2)
                i += 1
        if "id" not in item:
            raise FrontmatterError("rules item missing 'id'")
        if item.get("severity") not in ("error", "warn"):
            raise FrontmatterError(f"rule '{item.get('id')}': severity must be error|warn")
        items.append(item)
    if not items:
        raise FrontmatterError("empty rules block")
    return items, i


def _collect_indented(lines, i, indent):
    parts, n = [], len(lines)
    pad = " " * indent
    while i < n and (lines[i].startswith(pad) or not lines[i].strip()):
        if not lines[i].strip():
            break
        parts.append(lines[i].strip())
        i += 1
    if not parts:
        raise FrontmatterError(f"line {i}: expected indented continuation lines")
    return parts, i


def parse_frontmatter(text):
    """Tolerant parse for reads: strict first, naive fallback, never raises."""
    try:
        return parse_frontmatter_strict(text)
    except FrontmatterError:
        pass
    if not text.startswith("---"):
        return {}, text
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}, text
    meta = {}
    for line in parts[1].strip().splitlines():
        if ":" in line and not line.startswith(" "):
            k, v = line.split(":", 1)
            meta[k.strip()] = v.strip().strip("\"'")
    return meta, parts[2].lstrip("\n")


# ---------------- shared helpers ----------------

def h1_of(body):
    hs = [l[2:].strip() for l in body.splitlines() if l.startswith("# ")]
    return hs[0] if hs else None


def write_atomic(path, content):
    tmp = path.parent / f".{path.name}.tmp{os.getpid()}"
    tmp.write_text(content)
    os.replace(tmp, path)


def check_slug(s, what="slug"):
    if not SLUG_RE.match(s):
        die(f"invalid {what} {s!r} — must match ^[a-z0-9-]+$")


def book_dirs():
    if not LIB.is_dir():
        die(f"no library/ at {LIB}")
    return sorted(d for d in LIB.iterdir() if d.is_dir() and not d.name.startswith("."))


def book_dir(slug):
    check_slug(slug, "book slug")
    d = LIB / slug
    if not d.is_dir():
        die(f"book not found: {slug} (run `bk list`)")
    return d


def pages_of(d):
    return sorted(p for p in d.glob("*.md") if p.name not in RESERVED)


def book_description(d):
    idx = d / "index.md"
    if not idx.exists():
        return ""
    meta, body = parse_frontmatter(idx.read_text())
    if meta.get("description"):
        return meta["description"]
    for line in body.splitlines():
        s = line.strip()
        if s and not s.startswith("#"):
            return s.lstrip("*").split("**")[0].strip() if s.startswith("**") else s
    return ""


def session_id():
    sid = os.environ.get("CLAUDE_SESSION_ID")
    if sid:
        return re.sub(r"[^A-Za-z0-9_-]", "", sid)[:32]
    return f"{datetime.date.today().isoformat()}-{os.getppid()}"


def log_read(book, targets):
    try:
        rdir = DATA / "reads"
        rdir.mkdir(parents=True, exist_ok=True)
        pages = [{"page": t.stem,
                  "sha": hashlib.sha256(t.read_bytes()).hexdigest()[:12]} for t in targets]
        rec = {"ts": datetime.datetime.now().isoformat(timespec="seconds"),
               "role": os.environ.get("BK_ROLE", "unknown"),
               "book": book, "pages": pages}
        with open(rdir / f"{session_id()}.jsonl", "a") as f:
            f.write(json.dumps(rec) + "\n")
    except OSError:
        pass  # tracking must never block a read


# ---------------- commands ----------------

def cmd_list(args):
    rows = [{"slug": d.name, "pages": len(pages_of(d)), "description": book_description(d)}
            for d in book_dirs()]
    if args.json:
        print(json.dumps({"books": rows}, indent=2, ensure_ascii=False))
        return
    if not rows:
        print("library is empty — `bk create <slug> --title ...`")
        return
    w = max(len(r["slug"]) for r in rows)
    for r in rows:
        print(f"{r['slug']:<{w}}  {r['pages']:>3} pages  {r['description'][:80]}")


def cmd_toc(args):
    d = book_dir(args.book)
    rows = []
    for p in pages_of(d):
        meta, body = parse_frontmatter(p.read_text())
        rows.append({"page": p.stem, "type": meta.get("type", ""),
                     "title": h1_of(body) or p.stem,
                     "description": meta.get("description", "")})
    if args.json:
        print(json.dumps({"book": args.book, "pages": rows}, indent=2, ensure_ascii=False))
        return
    print(f"{args.book} — {len(rows)} pages (+ index, log)")
    for r in rows:
        print(f"  {r['page']:<28} [{r['type']:<9}] {r['description'][:80]}")


def cmd_read(args):
    for spec in args.specs:
        if ":" not in spec:
            die(f"bad spec '{spec}' — use <book>:<page,page> or <book>:all or <book>:index")
        book, pagespec = spec.split(":", 1)
        d = book_dir(book)
        if pagespec == "all":
            targets = [d / "index.md"] + pages_of(d)
        else:
            targets = []
            for slug in pagespec.split(","):
                slug = slug.strip().removesuffix(".md")
                if slug not in ("index", "log"):
                    check_slug(slug, "page slug")
                f = d / f"{slug}.md"
                if not f.exists():
                    die(f"page not found: {book}:{slug} (run `bk toc {book}`)")
                targets.append(f)
        log_read(book, targets)
        for t in targets:
            print(f"\n{'─' * 60}\n{book} · {t.stem}\n{'─' * 60}")
            print(t.read_text().rstrip())


def cmd_create(args):
    check_slug(args.slug, "book slug")
    d = LIB / args.slug
    if d.exists():
        die(f"book already exists: {args.slug}")
    d.mkdir(parents=True)
    today = datetime.date.today().isoformat()
    write_atomic(d / "index.md",
        f"---\ntitle: {args.title}\ndescription: {args.description or args.title}\n---\n\n"
        f"# Index\n\n**{args.title}.** {args.description}\n\n## Pages\n\n_(none yet)_\n")
    write_atomic(d / "log.md",
        f"# Changelog\n\nA chronological record of how this book evolves. "
        f"Most recent first.\n\n## [{today}] Book created\nEmpty scaffold — index and changelog only.\n")
    print(f"created {d.relative_to(ROOT)} (index.md + log.md)")


def cmd_put(args):
    if ":" not in args.target:
        die("target must be <book>:<page>")
    book, slug = args.target.split(":", 1)
    d = book_dir(book)
    slug = slug.removesuffix(".md")
    is_reserved = slug in ("index", "log")
    if not is_reserved:
        check_slug(slug, "page slug")
    content = sys.stdin.read() if args.file == "-" else pathlib.Path(args.file).read_text()
    if not is_reserved:
        # strict-or-die on writes
        try:
            meta, _ = parse_frontmatter_strict(content)
        except FrontmatterError as e:
            die(f"frontmatter rejected (strict subset): {e}")
        for req in ("type", "description"):
            if not meta.get(req):
                die(f"frontmatter rejected: missing required key '{req}'")
    f = d / f"{slug}.md"
    existed = f.exists()
    write_atomic(f, content)
    print(f"{'updated' if existed else 'created'} {f.relative_to(ROOT)}")


def cmd_grep(args):
    dirs = [book_dir(args.book)] if args.book else book_dirs()
    hits = 0
    needle = args.term.lower()
    for d in dirs:
        for p in sorted(d.glob("*.md")):
            for ln, line in enumerate(p.read_text().splitlines(), 1):
                if needle in line.lower():
                    print(f"{d.name}/{p.stem}:{ln}: {line.strip()[:120]}")
                    hits += 1
    if not hits:
        print(f"no matches for {args.term!r}")
        sys.exit(1)


def generate_index(d):
    idx = d / "index.md"
    meta, body = {}, ""
    if idx.exists():
        meta, body = parse_frontmatter(idx.read_text())
    # Reserved pages are frontmatter-less (Book 2, structure/reserved-pages-plain):
    # emit no frontmatter. A hand-written intro (first bold line of the existing
    # body) survives regeneration; legacy frontmatter title/description fold into
    # the intro once, then the frontmatter is gone for good.
    intro = next((ln for ln in body.splitlines() if ln.startswith("**")), "")
    if not intro:
        intro = f"**{meta.get('title', d.name)}.** {meta.get('description', '')}".rstrip()
    out = ["# Index", "", intro, "", "## Pages", ""]
    rows = []
    for p in pages_of(d):
        m, _ = parse_frontmatter(p.read_text())
        rows.append(f"| `{p.stem}` | {m.get('type','')} | {m.get('description','')} |")
    if rows:
        out += ["| Page | Type | Description |", "|---|---|---|"] + rows
    else:
        out.append("_(none yet)_")
    return "\n".join(out) + "\n"


def cmd_index(args):
    d = book_dir(args.book)
    content = generate_index(d)
    if getattr(args, "write", False):
        write_atomic(d / "index.md", content)
        print(f"regenerated {d.name}/index.md ({len(pages_of(d))} pages)")
    else:
        print(content)


def cmd_log(args):
    d = book_dir(args.book)
    f = d / "log.md"
    text = f.read_text() if f.exists() else "# Changelog\n\nMost recent first.\n"
    today = datetime.date.today().isoformat()
    entry = f"\n## [{today}] {args.entry}\n"
    marker = "Most recent first.\n"
    i = text.find(marker)
    pos = i + len(marker) if i != -1 else text.find("\n") + 1
    write_atomic(f, text[:pos] + entry + text[pos:])
    print(f"logged to {d.name}/log.md")


# ---------------- lint: the deterministic gate layer ----------------

def _lint_book(d, findings):
    def add(sev, page, rule, msg):
        findings.append({"severity": sev, "book": d.name, "page": page, "rule": rule, "msg": msg})

    # book level
    for sub in d.iterdir():
        if sub.is_dir():
            add("error", "-", "lint/flat-book", f"subdirectory {sub.name!r} — books are flat")
    for req in ("index.md", "log.md"):
        if not (d / req).exists():
            add("error", "-", "lint/reserved-files", f"missing {req}")
    idx_text = (d / "index.md").read_text() if (d / "index.md").exists() else ""
    log_text = (d / "log.md").read_text() if (d / "log.md").exists() else ""
    if log_text and "## [" not in log_text:
        add("warn", "log", "lint/log-has-entries", "changelog has no dated entries")

    for p in pages_of(d):
        slug, text = p.stem, p.read_text()
        if not SLUG_RE.match(slug):
            add("error", slug, "lint/kebab-filename", "filename must match ^[a-z0-9-]+$")
        try:
            meta, body = parse_frontmatter_strict(text)
        except FrontmatterError as e:
            add("error", slug, "lint/frontmatter-subset", str(e))
            meta, body = parse_frontmatter(text)
        for req in ("type", "description"):
            if not meta.get(req):
                add("error", slug, "lint/frontmatter-required", f"missing '{req}'")
        if REGISTRY_ENFORCED and meta.get("type") in ("rule", "template") and "rules" not in meta:
            add("error", slug, "lint/rules-registry", "rule-bearing page missing rules frontmatter")
        elif meta.get("type") in ("rule", "template") and "rules" not in meta:
            add("warn", slug, "lint/rules-registry", "rule-bearing page missing rules frontmatter (pre-registry: warn)")
        h1s = [l for l in body.splitlines() if l.startswith("# ")]
        if len(h1s) != 1:
            add("error", slug, "lint/single-h1", f"expected exactly one H1, found {len(h1s)}")
        if len(body.splitlines()) > PAGE_BUDGET_LINES:
            add("warn", slug, "lint/page-budget", f"{len(body.splitlines())} lines > {PAGE_BUDGET_LINES} (guideline)")
        if idx_text and slug not in idx_text:
            add("error", slug, "lint/index-current", "page not listed in index.md")
        for m in re.finditer(r"\]\(([^)#\s]+\.md)\)", body):
            rel = m.group(1)
            if rel.startswith("../"):
                # books are independent: cross-book references are plain-text
                # names ("the Subagents book · `page-slug`"), never links —
                # the librarian routes relationships; scouts report Leads.
                add("error", slug, "lint/cross-book-link",
                    f"cross-book link: {rel} — use a name-reference instead")
                continue
            target = (p.parent / rel).resolve()
            if not target.exists():
                add("error", slug, "lint/links-resolve", f"dead link: {rel}")
        if meta.get("type") == "recipe":
            low = body.lower()
            for section in ("prerequisite", "step", "verification", "failure mode"):
                if section not in low:
                    add("error", slug, "lint/recipe-sections", f"how-to page missing '{section}s' section")


def _lint_graduation_signals(findings):
    """Library-wide: a page whose slug matches a book elsewhere (exactly, or as
    the book slug's suffix — 'book-3-progressive-disclosure' vs page
    'progressive-disclosure') signals an unmigrated home. A properly graduated
    stub (short + links its book) is exempt."""
    book_slugs = {d.name for d in book_dirs()}
    for d in book_dirs():
        for p in pages_of(d):
            matches = [b for b in book_slugs if b != d.name
                       and (b == p.stem or b.endswith("-" + p.stem))]
            if not matches:
                continue
            text = p.read_text()
            _, body = parse_frontmatter(text)
            is_stub = len(body.splitlines()) <= 25 and any(b in text for b in matches)
            if not is_stub:
                findings.append({"severity": "warn", "book": d.name, "page": p.stem,
                                 "rule": "lint/graduation-signal",
                                 "msg": f"page shares its concept with book '{matches[0]}' — if same concept, graduate the page to a stub (structure/one-home-graduation)"})


def cmd_lint(args):
    findings = []
    if args.target == "library":
        for d in book_dirs():
            _lint_book(d, findings)
        _lint_graduation_signals(findings)
    else:
        _lint_book(book_dir(args.target), findings)
    if args.json:
        print(json.dumps({"findings": findings}, indent=2, ensure_ascii=False))
    else:
        for f in findings:
            print(f"{f['severity'].upper():5} {f['book']}/{f['page']:<26} {f['rule']:<26} {f['msg']}")
        errs = sum(1 for f in findings if f["severity"] == "error")
        warns = len(findings) - errs
        print(f"— {errs} error(s), {warns} warning(s)")
    if any(f["severity"] == "error" for f in findings):
        sys.exit(1)


# ---------------- coverage: which promises have a live eval ----------------
# The domain books own the bar (Book 2's rules: frontmatter); this command
# reconciles that rule registry against reference/coverage.tsv — the hand/tool-
# maintained ledger of which claims have which instrument at what status. A rule
# with no ledger row matching it is surfaced as uncovered (a regression guard on
# new rules). This is the generated form of book-6-evals' coverage matrix.

_COV_STATUS = ["running", "ran-once", "blocked", "not-run", "missing"]
_COV_MARK = {"running": "OK  ", "ran-once": "1x  ", "blocked": "BLK ",
             "not-run": "TODO", "missing": "GAP "}
_COV_COLS = ["rule_id", "claim", "owner", "instrument", "status", "evidence"]


def rule_registry():
    """Every rule id declared in the library's frontmatter -> book/page."""
    reg = {}
    for d in book_dirs():
        for p in pages_of(d):
            try:
                meta, _ = parse_frontmatter(p.read_text())
            except Exception:
                continue
            for r in meta.get("rules", []):
                if isinstance(r, dict) and r.get("id"):
                    reg[r["id"]] = f"{d.name}/{p.stem}"
    return reg


def _coverage_ledger():
    f = ROOT / "reference" / "coverage.tsv"
    rows = []
    if f.exists():
        for ln in f.read_text().splitlines():
            if not ln.strip() or ln.lstrip().startswith("#"):
                continue
            c = ln.split("\t")
            c += [""] * (len(_COV_COLS) - len(c))
            rows.append(dict(zip(_COV_COLS, c[:len(_COV_COLS)])))
    return rows


def _cov_matches(pattern, rid):
    if pattern == "*":
        return True
    if pattern.endswith("/*"):
        return rid.startswith(pattern[:-1])
    return pattern == rid


def cmd_coverage(args):
    reg = rule_registry()
    rows = _coverage_ledger()
    patterns = [r["rule_id"] for r in rows if r["rule_id"] and r["rule_id"] != "-"]
    uncovered = sorted(rid for rid in reg if not any(_cov_matches(p, rid) for p in patterns))
    if args.json:
        print(json.dumps({"rows": rows, "rules_total": len(reg),
                          "rules_uncovered": uncovered}, indent=2, ensure_ascii=False))
        return
    rows.sort(key=lambda r: (_COV_STATUS.index(r["status"]) if r["status"] in _COV_STATUS else 9,
                             r["claim"]))
    print("COVERAGE — which of the library's promises are tested, and how\n")
    for r in rows:
        print(f"  {_COV_MARK.get(r['status'], '??  ')} {r['claim'][:46]:46} "
              f"{r['instrument'][:22]:22} {r['evidence'][:30]}")
    counts = {}
    for r in rows:
        counts[r["status"]] = counts.get(r["status"], 0) + 1
    print("\n  " + "   ".join(f"{_COV_MARK.get(s, s).strip()}={counts[s]}"
                              for s in _COV_STATUS if s in counts))
    tail = f" -> {', '.join(uncovered)}" if uncovered else ""
    print(f"  registry: {len(reg)} rules - uncovered by any ledger row: {len(uncovered)}{tail}")


# ---------------- the enforced write path: gate + promote ----------------
# Drafts stage in drafts/<slug>/; nothing enters library/ except via `bk promote`,
# which requires a PASS verdict whose per-page sha256 still matches the draft.
# Layer 1 (lint) is fail-closed here; Layer 2 (the LLM verifier) is a gate subagent
# that records its verdict via `--verdict` — it invokes bk gate, it is never the gate.

def _draft_dir(slug):
    check_slug(slug, "book slug")
    d = ROOT / "drafts" / slug
    if not d.is_dir():
        die(f"no draft at drafts/{slug}/ (stage the book there first)")
    return d


def _verdict_path(slug):
    return DATA / "verdicts" / f"{slug}.json"


def _page_hashes(d):
    return {p.name: hashlib.sha256(p.read_bytes()).hexdigest() for p in sorted(d.glob("*.md"))}


def cmd_gate(args):
    d = _draft_dir(args.slug)
    findings = []
    _lint_book(d, findings)
    lint_errors = [f for f in findings if f["severity"] == "error"]
    lint_ok = not lint_errors
    result = "REJECT" if not lint_ok else (args.verdict or "PENDING")
    artifact = {
        "slug": args.slug,
        "ts": datetime.datetime.now().isoformat(timespec="seconds"),
        "lint": "pass" if lint_ok else "fail",
        "lint_findings": [f"{f['rule']}: {f['page']} — {f['msg']}" for f in lint_errors],
        "files": _page_hashes(d),
        "result": result,
        "by": args.by,
    }
    vp = _verdict_path(args.slug)
    vp.parent.mkdir(parents=True, exist_ok=True)
    write_atomic(vp, json.dumps(artifact, indent=2, ensure_ascii=False) + "\n")
    for f in lint_errors:
        print(f"LINT  {f['page']:<26} {f['rule']:<24} {f['msg']}")
    try:
        vp_disp = vp.relative_to(ROOT)
    except ValueError:          # BK_DATA outside BK_ROOT — show it absolute
        vp_disp = vp
    print(f"gate {args.slug}: lint={'pass' if lint_ok else 'FAIL'} · result={result} · "
          f"verdict → {vp_disp}")
    if not lint_ok or result == "REJECT":
        sys.exit(1)


def cmd_promote(args):
    d = _draft_dir(args.slug)
    vp = _verdict_path(args.slug)
    if not args.force:
        if not vp.exists():
            die(f"no verdict for {args.slug} — run `bk gate {args.slug} --verdict PASS` first (or --force)")
        artifact = json.loads(vp.read_text())
        if artifact.get("result") != "PASS":
            die(f"verdict is {artifact.get('result')}, not PASS — cannot promote (or --force)")
        if artifact.get("files") != _page_hashes(d):
            die(f"draft content changed since gate — re-gate {args.slug} (or --force)")
    dst = LIB / args.slug
    LIB.mkdir(parents=True, exist_ok=True)
    backup = None
    if dst.exists():
        backup = LIB / f".{args.slug}.promote-bak"
        if backup.exists():
            shutil.rmtree(backup)
        os.rename(dst, backup)
    try:
        os.rename(d, dst)
    except OSError:
        if backup:
            os.rename(backup, dst)
        raise
    if backup:
        shutil.rmtree(backup)
    if vp.exists():
        a = json.loads(vp.read_text())
        a["promoted"] = datetime.datetime.now().isoformat(timespec="seconds")
        a["forced"] = bool(args.force)
        write_atomic(vp, json.dumps(a, indent=2, ensure_ascii=False) + "\n")
    print(f"promoted {args.slug} → library/{args.slug}" + ("  (FORCED)" if args.force else ""))


def main():
    ap = argparse.ArgumentParser(prog="bk", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("list");   p.add_argument("--json", action="store_true"); p.set_defaults(fn=cmd_list)
    p = sub.add_parser("toc");    p.add_argument("book"); p.add_argument("--json", action="store_true"); p.set_defaults(fn=cmd_toc)
    p = sub.add_parser("read");   p.add_argument("specs", nargs="+"); p.set_defaults(fn=cmd_read)
    p = sub.add_parser("grep");   p.add_argument("term"); p.add_argument("--book"); p.set_defaults(fn=cmd_grep)
    p = sub.add_parser("index");  p.add_argument("book")
    if not BUNDLE_BUILD:
        p.add_argument("--write", action="store_true")
    p.set_defaults(fn=cmd_index)
    if not BUNDLE_BUILD:
        # write verbs exist only in the authoring repo — a shipped bundle's CLI
        # simply doesn't have them ("invalid choice"), nothing to guard
        p = sub.add_parser("create"); p.add_argument("slug"); p.add_argument("--title", required=True); p.add_argument("--description", default=""); p.set_defaults(fn=cmd_create)
        p = sub.add_parser("put");    p.add_argument("target"); p.add_argument("--file", required=True); p.set_defaults(fn=cmd_put)
        p = sub.add_parser("log");    p.add_argument("book"); p.add_argument("--entry", required=True); p.set_defaults(fn=cmd_log)
        p = sub.add_parser("gate");    p.add_argument("slug"); p.add_argument("--verdict", choices=["PASS", "REJECT"]); p.add_argument("--by", default="unknown"); p.set_defaults(fn=cmd_gate)
        p = sub.add_parser("promote"); p.add_argument("slug"); p.add_argument("--force", action="store_true"); p.set_defaults(fn=cmd_promote)
    p = sub.add_parser("lint");   p.add_argument("target"); p.add_argument("--json", action="store_true"); p.set_defaults(fn=cmd_lint)
    p = sub.add_parser("coverage"); p.add_argument("--json", action="store_true"); p.set_defaults(fn=cmd_coverage)

    args = ap.parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
